@using NewMvcApp.Models
@model List<Product>
<h1>Product details</h1>
<table border="1" class="table">
        <tr>
        <th>Id</th>
        <th>Name</th>
        <th>Category</th>
        <th>Price</th>
        <th>Action</th>
        </tr>
     @foreach(var p in Model){
        <tr>
            <td>@p.Id</td>
            <td>@p.Name</td>
            <td>@p.Category</td>
            <td>@p.Price</td>
            <td> <a asp-action="Details" asp-route-id="@p.Id">View Details</a></td>
        </tr>
     }
</table>