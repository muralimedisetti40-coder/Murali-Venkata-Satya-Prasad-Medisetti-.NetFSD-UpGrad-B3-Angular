@model ContactManagementSystem.Models.ContactInfo

<h2>Delete Contact</h2>

<h4>Are you sure you want to delete this?</h4>

<div>
    <p><b>Name:</b> @Model.FirstName @Model.LastName</p>
    <p><b>Email:</b> @Model.EmailId</p>
    <p><b>Designation:</b> @Model.Designation</p>
</div>

<form asp-action="DeleteContact" method="post">
    <input type="hidden" asp-for="id" />
    
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="ShowContacts" class="btn btn-secondary">Cancel</a>
</form>