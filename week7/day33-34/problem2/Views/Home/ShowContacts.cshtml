@model List<ContactManagementSystem.Models.ContactInfo>

<h2>Contact List</h2>

<a asp-action="AddContact" class="btn btn-primary">Add New Contact</a>

<table class="table table-bordered mt-3">
    <thead>
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Mobile</th>
            <th>Designation</th>
            <th>Company</th>
            <th>Department</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.FirstName</td>
            <td>@item.LastName</td>
            <td>@item.EmailId</td>
            <td>@item.MobileNo</td>
            <td>@item.Designation</td>
            <td>@item.Company?.Companyname</td>
            <td>@item.Department?.Departmentname</td>
            <td>
                <a asp-action="EditContact" asp-route-id="@item.id" class="btn btn-warning">Edit</a>
                <a asp-action="DeleteContact" asp-route-id="@item.id" class="btn btn-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>