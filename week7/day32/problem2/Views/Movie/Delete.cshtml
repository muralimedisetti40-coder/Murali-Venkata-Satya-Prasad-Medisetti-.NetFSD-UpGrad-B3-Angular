@model Movie

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Movie details</h4>
    <hr />
    <p>Title:@Model.Title</p>
    <p>Title:@Model.Genre</p>
    <p>Title:@Model.ReleaseDate</p>
    <p>Title:@Model.Price</p>
    <p>Title:@Model.Rating</p>
    
    <form asp-action="Remove" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="ToList">Back to List</a>
    </form>
</div>